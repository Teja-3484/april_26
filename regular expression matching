class Solution:
    def isMatch(self, s: str, p: str) -> bool:
        if p=="":
            return s==""
        first = len(s)>0 and (s[0]==p[0] or p[0]=='.')
        if len(p)>1 and p[1]=='*':
            return (self.isMatch(s,p[2:]) or 
                    (first and self.isMatch(s[1:],p)))
        else:
            return first and self.isMatch(s[1:],p[1:])
