class Solution:
    def largestNumber(self, nums: List[int]) -> str:
        nums=list(map(str,nums))
        nums.sort(reverse=True)
        for i in range(len(nums)):
            for j in range(i+1,len(nums)):
                if nums[i]+nums[j] < nums[j]+nums[i]:
                    nums[i],nums[j]=nums[j],nums[i]
        s=""
        for i in nums:
            s+=i
        if s[0]=="0":
            return "0"
        return s
